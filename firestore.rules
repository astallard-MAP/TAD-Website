rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // User Profiles
    match /users/{userId} {
      // Allow read/write if the user is the owner OR is the Global Administrator
      allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == 'G9S36zhuhKQeDXW0YgBY28FdLTZ2');
    }
    
    // Properties: Publicly readable, admin only write
    match /properties/{propertyId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == 'G9S36zhuhKQeDXW0YgBY28FdLTZ2');
    }
  }
}
