rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Avatars: Users can read any avatar, but only write to their own file/folder
    match /avatars/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == 'G9S36zhuhKQeDXW0YgBY28FdLTZ2');
    }
    
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == 'G9S36zhuhKQeDXW0YgBY28FdLTZ2');
    }
    
    // Documents: Only the owner or a global admin can access AML documents
    match /documents/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == 'G9S36zhuhKQeDXW0YgBY28FdLTZ2');
    }
  }
}
